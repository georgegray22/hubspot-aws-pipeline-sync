# =============================================================================
# AWS HubSpot Sync — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Partner Central (ACE) API [REQUIRED]
# -----------------------------------------------------------------------------
# Create an IAM user with partnercentral-selling permissions.
# See README.md "AWS IAM Setup" section for the exact policy.
AWS_ACE_ACCESS_KEY_ID=
AWS_ACE_SECRET_ACCESS_KEY=

# Your ACE solution ID (find this in Partner Central under Solutions)
# [REQUIRED]
ACE_SOLUTION_ID=

# Catalog: "Sandbox" for testing, "AWS" for production
ACE_CATALOG=Sandbox

# AWS region for ACE API (almost always us-east-1)
ACE_REGION=us-east-1

# User agent sent to AWS — format: CompanyName|ConnectorName|CRM|Version
# Replace with your company name
ACE_USER_AGENT=YourCompany|ACEConnector|HubSpot|1.0

# -----------------------------------------------------------------------------
# HubSpot API [REQUIRED]
# -----------------------------------------------------------------------------
# Create a Private App in HubSpot with deal read/write and company/contact read scopes.
# See README.md "HubSpot Setup" section.
HUBSPOT_API_KEY=

# Your HubSpot portal ID (find it in Settings → Account → Account Information)
# Required for Slack deal links. Without this, deal notifications won't include clickable links.
HUBSPOT_PORTAL_ID=

# HubSpot data center region: "na1" (North America), "eu1" (Europe)
HUBSPOT_REGION=na1

# The pipeline ID to sync. Find it in Settings → Deals → Pipelines.
# Most HubSpot accounts have a "default" pipeline.
# [REQUIRED]
HUBSPOT_PIPELINE_ID=default

# -----------------------------------------------------------------------------
# Stage Mapping [REQUIRED]
#
# This is the MOST IMPORTANT configuration. You must map YOUR HubSpot deal
# stage IDs to AWS ACE pipeline stages.
#
# To find your stage IDs:
#   1. Go to HubSpot Settings → Deals → Pipelines
#   2. Click on your pipeline
#   3. Use the HubSpot API: GET /crm/v3/pipelines/deals/{pipelineId}/stages
#
# Valid ACE stages (in order):
#   Qualified → Technical Validation → Business Validation →
#   Committed → Launched → Closed Lost
#
# Format: <YOUR_HUBSPOT_STAGE_ID>=ACE Stage Name (semicolon-separated pairs)
#
# Example (replace the left side with your actual HubSpot stage IDs):
#
#   STAGE_MAPPING="abc123=Qualified;def456=Technical Validation;..."
#
# -----------------------------------------------------------------------------
STAGE_MAPPING="\
<YOUR_QUALIFIED_STAGE_ID>=Qualified;\
<YOUR_EVAL_STAGE_ID>=Technical Validation;\
<YOUR_REVIEW_STAGE_ID>=Business Validation;\
<YOUR_NEGOTIATION_STAGE_ID>=Committed;\
<YOUR_CLOSED_WON_STAGE_ID>=Launched;\
<YOUR_CLOSED_LOST_STAGE_ID>=Closed Lost"

# Human-readable display names for YOUR stages (used in Slack messages).
# Replace <YOUR_..._STAGE_ID> with the same IDs you used in STAGE_MAPPING.
STAGE_DISPLAY_NAMES="\
<YOUR_QUALIFIED_STAGE_ID>=Qualified;\
<YOUR_EVAL_STAGE_ID>=Technical Eval;\
<YOUR_REVIEW_STAGE_ID>=Business Review;\
<YOUR_NEGOTIATION_STAGE_ID>=Negotiation;\
<YOUR_CLOSED_WON_STAGE_ID>=Closed Won;\
<YOUR_CLOSED_LOST_STAGE_ID>=Closed Lost"

# Which stages should be synced to ACE (comma-separated HubSpot stage IDs).
# Replace <YOUR_..._STAGE_ID> with the same IDs you used above.
SYNC_ELIGIBLE_STAGES="\
<YOUR_QUALIFIED_STAGE_ID>,\
<YOUR_EVAL_STAGE_ID>,\
<YOUR_REVIEW_STAGE_ID>,\
<YOUR_NEGOTIATION_STAGE_ID>,\
<YOUR_CLOSED_WON_STAGE_ID>,\
<YOUR_CLOSED_LOST_STAGE_ID>"

# Stages to SKIP — too early for ACE (comma-separated HubSpot stage IDs).
# Deals in these stages will be ignored even if submit_to_aws=true.
SKIP_STAGES="\
<YOUR_DISCOVERY_STAGE_ID>,\
<YOUR_DEMO_STAGE_ID>"

# -----------------------------------------------------------------------------
# Slack Notifications (optional)
# -----------------------------------------------------------------------------
# Create a Slack app with chat:write scope, install to your workspace.
# If not set, the sync still runs — you just won't get Slack notifications.
SLACK_BOT_TOKEN=
ACE_SLACK_CHANNEL=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Set to DEBUG for verbose output, INFO for normal operation
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# HubSpot Custom Field Name Overrides (optional)
#
# If your HubSpot custom properties use different internal names than the
# defaults, override them here. Most users can leave these blank.
# -----------------------------------------------------------------------------
# HS_SUBMIT_FIELD=submit_to_aws
# HS_ACE_OPP_ID_FIELD=ace_opportunity_id
# HS_ACE_STATUS_FIELD=ace_sync_status
# HS_ACE_LAST_SYNC_FIELD=ace_last_sync
# HS_ACE_ERROR_FIELD=ace_sync_error
# HS_ACE_DESCRIPTION_FIELD=ace_project_description
# HS_CONTRACT_TERM_FIELD=contract_term__months_
# HS_ACE_AM_FIELD=ace_aws_account_manager
# HS_ACE_AM_EMAIL_FIELD=ace_aws_account_manager_email
# HS_ACE_SR_FIELD=ace_aws_sales_rep
# HS_ACE_SR_EMAIL_FIELD=ace_aws_sales_rep_email
# HS_ACE_PSM_FIELD=ace_aws_partner_sales_manager
# HS_ACE_PDM_FIELD=ace_aws_partner_development_manager
